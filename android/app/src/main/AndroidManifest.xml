<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.NFC" />
    <!--
      Android 14+ Foreground Service contract is fully satisfied here:
        • FOREGROUND_SERVICE permission (this declaration)
        • FOREGROUND_SERVICE_DATA_SYNC type-specific permission (below)
        • android:foregroundServiceType="dataSync" on MonitoringService
      Lint's pairing check can't verify these together across element
      boundaries, so we silence the matching IDs explicitly. The list is
      broad on purpose: AGP has moved the underlying inspection between
      `ForegroundServicePermission`, `ForegroundServiceType`, and
      `MissingForegroundServiceType` over the last few releases, and the
      IDE-side inspection sometimes uses one ID while `./gradlew lint`
      uses another.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"
        tools:ignore="ForegroundServicePermission,ForegroundServiceType,MissingForegroundServiceType,SpecialUseFgsType" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature android:name="android.hardware.nfc" android:required="false" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.QuailSync"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.QuailSync">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.nfc.action.TAG_DISCOVERED" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!--
              Fresh / blank NFC tags from the factory have no NDEF records,
              so they dispatch TECH_DISCOVERED (matched via NdefFormatable in
              nfc_tech_filter.xml) rather than NDEF_DISCOVERED. Without this
              filter + its tech-list resource, blank tags either fall through
              to TAG_DISCOVERED (lowest priority — gets pre-empted by other
              apps) or aren't delivered at all on cold launch.

              The runtime foregroundDispatch in NfcService already registers
              equivalent tech-lists, so this only matters when the activity
              isn't already foregrounded — but the manifest gap was confusing
              new-tag detection during the batch flow regardless.
            -->
            <intent-filter>
                <action android:name="android.nfc.action.TECH_DISCOVERED" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.nfc.action.TECH_DISCOVERED"
                android:resource="@xml/nfc_tech_filter" />
        </activity>

        <service
            android:name=".data.MonitoringService"
            android:foregroundServiceType="dataSync"
            android:exported="false"
            tools:ignore="ForegroundServicePermission,ForegroundServiceType,MissingForegroundServiceType,SpecialUseFgsType" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
