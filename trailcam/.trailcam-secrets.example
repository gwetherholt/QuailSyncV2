# Example secrets file for the trail-camera pipeline systemd unit.
#
# Copy this to /home/gwetherholt/.trailcam-secrets, fill in the real values,
# and lock it down so only the owner can read it:
#
#   cp trailcam/.trailcam-secrets.example /home/gwetherholt/.trailcam-secrets
#   chmod 600 /home/gwetherholt/.trailcam-secrets
#   editor /home/gwetherholt/.trailcam-secrets
#
# Format: KEY=value, one per line. No quotes, no spaces around '='. The systemd
# unit loads it via `EnvironmentFile=`. The real file must NEVER be committed
# (the .trailcam-secrets name is git-ignored).

SPYPOINT_USERNAME=you@example.com
SPYPOINT_PASSWORD=changeme

# --- Roboflow pre-annotation upload (optional, opt-in) ---------------------
# When enabled, each processed image + its YOLO predictions are uploaded to
# Roboflow as reviewable pre-labels. Leave ROBOFLOW_UPLOAD_ENABLED=false (or the
# API key unset) to skip it entirely. Requires `pip install roboflow`.
ROBOFLOW_UPLOAD_ENABLED=false
ROBOFLOW_API_KEY=your-roboflow-api-key
ROBOFLOW_WORKSPACE=quail
ROBOFLOW_PROJECT=quail-detector-3bm3l
# ROBOFLOW_BATCH_NAME=trailcam-auto

# Optional: any other config var from config.py can be overridden here too,
# e.g. uncomment to raise the per-photo size cap:
# MAX_PHOTO_SIZE_BYTES=20971520
