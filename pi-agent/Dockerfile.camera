FROM python:3.13-slim
RUN apt-get update && apt-get install -y \
    libcap-dev \
    libcamera0.5 \
    libfmt11 \
    libjpeg62-turbo \
    zbar-tools \
    libzbar0 \
    && rm -rf /var/lib/apt/lists/*
RUN pip install picamera2 websockets psutil pyzbar pillow
WORKDIR /app
COPY camera_stream.py .
