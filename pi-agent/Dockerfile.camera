FROM debian:trixie-slim
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/host-packages:$PYTHONPATH
RUN apt-get update && apt-get install -y python3 python3-pip python3-numpy python3-pil libcap2 && rm -rf /var/lib/apt/lists/*
RUN pip install --break-system-packages websockets psutil pyzbar
WORKDIR /app
COPY camera_stream.py .
