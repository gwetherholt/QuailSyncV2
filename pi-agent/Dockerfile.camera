FROM debian:trixie-slim
ENV PYTHONUNBUFFERED=1
RUN apt-get update && apt-get install -y python3 python3-pip && rm -rf /var/lib/apt/lists/*
RUN pip install --break-system-packages numpy pillow websockets psutil pyzbar
WORKDIR /app
COPY camera_stream.py .
CMD ["python3", "camera_stream.py", "--server", "ws://localhost:3000/ws", "--brooder-id", "1", "--camera-index", "0", "--port", "8080"]
