# Indoor pipeline (stage 3) secrets — TEMPLATE. Copy to the out-of-repo secrets
# file the systemd unit reads, lock it down, and fill in the real values. NEVER
# commit real credentials (the real .indoor-pipeline-secrets name is git-ignored).
#
#   install -m 600 /dev/null /home/gwetherholt/.indoor-pipeline-secrets
#   editor /home/gwetherholt/.indoor-pipeline-secrets   # set the two values below
#   # (owned by the service user, chmod 600 — not readable by other users)
#
# The systemd unit loads this via EnvironmentFile=. Format: KEY=value, one per
# line, no quotes, no spaces around '='.

# Indoor Tapo camera source — an RTSP stream URL (cv2.VideoCapture handles it).
# The URL embeds credentials; keeping it here (not in config.json) is why
# config.json ships with only `source_env`, not the address itself.
INDOOR_RTSP_URL=rtsp://quailcam:<pass>@192.168.0.181:554/stream1

# Roboflow API key — required for frame + pre-annotation auto-upload
# (roboflow.enabled in config.json). Leave it unset to skip uploads silently; the
# pipeline still runs. Same key as the trail-cam / incubator pipelines; uploads
# go to the mode's project (incubation-stages or find-chicks-5, see config.json).
ROBOFLOW_API_KEY=<key>

# Optional: point at an alternate config.json (default: indoor-pipeline/config.json).
# INDOOR_PIPELINE_CONFIG=/home/gwetherholt/QuailSyncV2/indoor-pipeline/config.json
