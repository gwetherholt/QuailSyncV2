/target
.claude/
*.db
certs/
__pycache__/

# Training data and outputs
training/
*.pt

# Runtime data + SQLite sidecars + Pi-agent crash dumps. Anchored (/data/, not
# `data/`) so it ignores only the repo-root dir, never a source package named
# `data` elsewhere (e.g. the Android app's com.quailsync.app.data).
/data/
pi-agent/core.*
*.db-journal
*.db-wal

# Trail-cam secrets — real credentials file must never be committed
# (the .example template is intentionally NOT ignored).
.trailcam-secrets
.indoor-cam-secrets
.incubator-secrets

# Incubator pipeline runtime artifacts: the reference frame(s) captured by
# define_rois.py and any locally-configured captures dir. The .example secrets
# template and config.json are intentionally NOT ignored.
incubator/reference.jpg
incubator/reference_annotated.jpg
incubator/captures/

# Indoor-cam YOLO model binaries live here on the Pi but must not bloat the repo
# (nor be wiped by an rsync deploy). Ignore the contents but keep the directory
# via .gitkeep so the models/ path exists in a fresh checkout.
indoor-cam/models/*
!indoor-cam/models/.gitkeep
