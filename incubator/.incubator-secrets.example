# Incubator capture pipeline secrets — TEMPLATE. Copy to the out-of-repo secrets
# file the systemd unit reads, lock it down, and fill in the real value. NEVER
# commit real credentials (the real .incubator-secrets name is git-ignored).
#
#   install -m 600 /dev/null /home/gwetherholt/.incubator-secrets
#   editor /home/gwetherholt/.incubator-secrets   # set INCUBATOR_RTSP_URL
#   # (owned by the service user, chmod 600 — not readable by other users)
#
# The systemd unit loads this via EnvironmentFile=. Format: KEY=value, one per
# line, no quotes, no spaces around '='.

# Camera source for the incubator tray — an RTSP stream URL or an HTTP snapshot
# URL (cv2.VideoCapture handles both). The URL may embed credentials
# (rtsp://user:pass@host:554/stream1); keeping it here (not in config.json) is
# why config.json ships with only `source_env`, not the address itself.
INCUBATOR_RTSP_URL=rtsp://username:password@CAMERA_IP:554/stream1

# Optional: point at an alternate config.json (default: incubator/config.json).
# INCUBATOR_CONFIG=/home/gwetherholt/QuailSyncV2/incubator/config.json
