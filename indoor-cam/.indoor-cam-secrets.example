# Indoor-camera (RTSP) secrets — TEMPLATE. Copy to the out-of-repo secrets file
# the systemd unit reads, lock it down, and fill in real values. NEVER commit
# real credentials.
#
#   install -m 600 /dev/null /home/gwetherholt/.indoor-cam-secrets
#   editor /home/gwetherholt/.indoor-cam-secrets
#   # (owned by the service user, chmod 600 — not readable by other users)
#
# Provide EITHER the full URL (with credentials) ...
RTSP_URL=rtsp://username:password@CAMERA_IP:554/stream1
#
# ... OR the components below (RTSP_URL takes precedence if both are set). The
# poller percent-encodes the username/password, so special characters are fine.
# RTSP_USERNAME=username
# RTSP_PASSWORD=password
# RTSP_HOST=CAMERA_IP
# RTSP_PORT=554
# RTSP_PATH=/stream1
#
# Roboflow active-learning API key — the SAME key the trail-cam pipeline uses.
# Uploads go to the find-chicks-5 project (set via ROBOFLOW_PROJECT in the unit).
ROBOFLOW_API_KEY=your-roboflow-api-key
